{
  "name": "cf-guestbook",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev -- vite",
    "build:widget": "vite build --config vite.widget.config.ts",
    "build:admin": "vite build --config vite.admin.config.ts",
    "build": "npm run build:widget && npm run build:admin",
    "preview": "wrangler pages dev dist",
    "db:init": "wrangler d1 execute guestbook --local --file=sql/001_init.sql",
    "db:seed": "wrangler d1 execute guestbook --local --file=sql/002_seed.sql",
    "db:init:remote": "wrangler d1 execute guestbook --remote --file=sql/001_init.sql",
    "db:seed:remote": "wrangler d1 execute guestbook --remote --file=sql/002_seed.sql"
  },
  "dependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.4.0",
    "pinia": "^2.2.0",
    "naive-ui": "^2.40.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wrangler": "^3.80.0",
    "@cloudflare/workers-types": "^4.20241004.0"
  }
}
